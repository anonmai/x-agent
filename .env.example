
# 网络代理（如需代理访问 X API）
HTTPS_PROXY=http://127.0.0.1:
HTTP_PROXY=http://127.0.0.1:

# OAuth 2.0 User Context（用户授权后获得的 Access Token，用于发帖与 v2 用户操作）
# 在开发者门户创建 OAuth 2.0 应用，完成授权流程后填入；与 OAuth 1.0a 的 Key/Secret 不同。
X_OAUTH2_ACCESS_TOKEN=

# 可选：仅用 Refresh Token 换 Access Token（需授权时勾选 offline.access；保密应用需 Client Secret）
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH2_REFRESH_TOKEN=

# 可选：启用 LLM 风格改写（否则为规则降级）
OPENAI_API_KEY=
