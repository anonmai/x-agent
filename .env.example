# 网络代理（如需代理访问 X API）
HTTPS_PROXY=http://127.0.0.1:
HTTP_PROXY=http://127.0.0.1:

# OAuth 2.0 Application-Only（搜索接口：recent/all）
# 在开发者门户生成 App Bearer Token。
X_APP_BEARER_TOKEN=

# OAuth 2.0 User Context（发帖/用户态接口）
X_CLIENT_ID=
X_CLIENT_SECRET=
# 可选：仅用 Refresh Token 换 Access Token（需授权时勾选 offline.access）
X_OAUTH2_ACCESS_TOKEN=
X_OAUTH2_REFRESH_TOKEN=

# DeepSeek API 配置
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 趋势配置
# WOEID (Where On Earth ID) 常见地区ID:
# 1: 全球
# 23424977: 美国
# 23424975: 英国
# 23424856: 日本
# 23424803: 中国
# 23424938: 加拿大
# 23424848: 澳大利亚
TRENDS_WOEID=1
TRENDS_MAX=10
TRENDS_SELECTED_INDEX=0

# 搜索配置
SEARCH_MAX_RESULTS=10
SEARCH_MODE=all

# 缓存配置
CACHE_DIRECTORY=./cache

# 日志配置
LOG_LEVEL=info
