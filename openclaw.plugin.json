{
  "id": "x-intelligent-publisher",
  "name": "X 自动发帖",
  "version": "1.0.0",
  "description": "X API v2 双鉴权：App-only Bearer 用于搜索（recent/all），OAuth 2.0 用户上下文用于发帖与用户态接口。",
  "skills": ["."],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "appBearerToken": {
        "type": "string",
        "description": "OAuth 2.0 Application-Only Bearer（搜索接口）"
      },
      "oauth2AccessToken": {
        "type": "string",
        "description": "OAuth 2.0 User Access Token（Bearer）"
      },
      "clientId": {
        "type": "string",
        "description": "OAuth 2.0 Client ID（与 refresh token 联用）"
      },
      "clientSecret": {
        "type": "string",
        "description": "OAuth 2.0 Client Secret（保密应用）"
      },
      "oauth2RefreshToken": {
        "type": "string",
        "description": "OAuth 2.0 Refresh Token（需 offline.access）"
      }
    }
  }
}
