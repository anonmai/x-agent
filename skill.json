{
  "id": "x-intelligent-publisher",
  "name": "x自动发帖智能体",
  "description": "X API v2 轻量模块：App-only Bearer 用于搜索，OAuth 2.0 User Context 用于发帖与用户态接口。",
  "version": "1.0.0",
  "author": "Bai",
  "type": "script",
  "license": "Apache-2.0",
  "private": true,
  "tags": ["X", "推特", "自动化", "发帖"],
  "user-invocable": true,
  "disable-model-invocation": false,
  "triggers": ["X", "推文", "发帖"],
  "permissions": {
    "network_access": true,
    "file_system": "read_write",
    "browser_automation": false,
    "environment_variables": true,
    "shell_exec": true,
    "clipboard_access": false,
    "notification": true
  },
  "requires": {
    "bins": ["node"],
    "os": ["darwin", "linux", "win32"]
  }
}